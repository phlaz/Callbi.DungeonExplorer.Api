<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dungeon="clr-namespace:DungeonExplorer.Client.Maui.Dungeon"
             x:Class="DungeonExplorer.Client.Maui.Dungeon.DungeonGrid">

    <CollectionView ItemsSource="{Binding Cells}" ItemsLayout="Grid, 10">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="dungeon:Cell">
                <Border Padding="5" Margin="2"
                       BackgroundColor="{Binding IsWall, Converter={StaticResource BoolToColorConverter}}">
                    <Label Text="{Binding X}" />
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>